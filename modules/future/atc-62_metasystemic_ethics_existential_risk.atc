module Future::MetasystemicEthicsExistentialRisk {

    struct MetasystemicEthicsExistentialRiskState {
        id: u64,
        anchor_hash: Hash,
        metadata: String,
        registered_at: u64,
    }

    contract MetasystemicEthicsExistentialRiskRegistry {
        state entries: Map<u64, MetasystemicEthicsExistentialRiskState>
        state next_id: u64
        state owner: Address

        event MetasystemicEthicsExistentialRiskRegistered(id: u64, anchor_hash: Hash)

        fn init(owner: Address) -> bool {
            self.owner = owner
            return true
        }

        fn register(anchor_hash: Hash, metadata: String) -> u64 {
            let id: u64 = self.next_id
            self.entries[id] = MetasystemicEthicsExistentialRiskState {
                id: id, anchor_hash: anchor_hash, metadata: metadata,
                registered_at: block_timestamp(),
            }
            self.next_id += 1
            emit MetasystemicEthicsExistentialRiskRegistered(id, anchor_hash)
            return id
        }

        fn get(id: u64) -> MetasystemicEthicsExistentialRiskState {
            return self.entries[id]
        }
    }
}
