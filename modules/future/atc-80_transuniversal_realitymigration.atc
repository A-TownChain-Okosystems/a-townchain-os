module Future::TransuniversalRealitymigration {

    struct TransuniversalRealitymigrationState {
        id: u64,
        anchor_hash: Hash,
        metadata: String,
        registered_at: u64,
    }

    contract TransuniversalRealitymigrationRegistry {
        state entries: Map<u64, TransuniversalRealitymigrationState>
        state next_id: u64
        state owner: Address

        event TransuniversalRealitymigrationRegistered(id: u64, anchor_hash: Hash)

        fn init(owner: Address) -> bool {
            self.owner = owner
            return true
        }

        fn register(anchor_hash: Hash, metadata: String) -> u64 {
            let id: u64 = self.next_id
            self.entries[id] = TransuniversalRealitymigrationState {
                id: id, anchor_hash: anchor_hash, metadata: metadata,
                registered_at: block_timestamp(),
            }
            self.next_id += 1
            emit TransuniversalRealitymigrationRegistered(id, anchor_hash)
            return id
        }

        fn get(id: u64) -> TransuniversalRealitymigrationState {
            return self.entries[id]
        }
    }
}
