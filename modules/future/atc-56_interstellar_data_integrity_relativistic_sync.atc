module Future::InterstellarDataIntegrityRelativisticSync {

    struct InterstellarDataIntegrityRelativisticSyncState {
        id: u64,
        anchor_hash: Hash,
        metadata: String,
        registered_at: u64,
    }

    contract InterstellarDataIntegrityRelativisticSyncRegistry {
        state entries: Map<u64, InterstellarDataIntegrityRelativisticSyncState>
        state next_id: u64
        state owner: Address

        event InterstellarDataIntegrityRelativisticSyncRegistered(id: u64, anchor_hash: Hash)

        fn init(owner: Address) -> bool {
            self.owner = owner
            return true
        }

        fn register(anchor_hash: Hash, metadata: String) -> u64 {
            let id: u64 = self.next_id
            self.entries[id] = InterstellarDataIntegrityRelativisticSyncState {
                id: id, anchor_hash: anchor_hash, metadata: metadata,
                registered_at: block_timestamp(),
            }
            self.next_id += 1
            emit InterstellarDataIntegrityRelativisticSyncRegistered(id, anchor_hash)
            return id
        }

        fn get(id: u64) -> InterstellarDataIntegrityRelativisticSyncState {
            return self.entries[id]
        }
    }
}
