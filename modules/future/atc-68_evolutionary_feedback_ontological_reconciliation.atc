module Future::EvolutionaryFeedbackOntologicalReconciliation {

    struct EvolutionaryFeedbackOntologicalReconciliationState {
        id: u64,
        anchor_hash: Hash,
        metadata: String,
        registered_at: u64,
    }

    contract EvolutionaryFeedbackOntologicalReconciliationRegistry {
        state entries: Map<u64, EvolutionaryFeedbackOntologicalReconciliationState>
        state next_id: u64
        state owner: Address

        event EvolutionaryFeedbackOntologicalReconciliationRegistered(id: u64, anchor_hash: Hash)

        fn init(owner: Address) -> bool {
            self.owner = owner
            return true
        }

        fn register(anchor_hash: Hash, metadata: String) -> u64 {
            let id: u64 = self.next_id
            self.entries[id] = EvolutionaryFeedbackOntologicalReconciliationState {
                id: id, anchor_hash: anchor_hash, metadata: metadata,
                registered_at: block_timestamp(),
            }
            self.next_id += 1
            emit EvolutionaryFeedbackOntologicalReconciliationRegistered(id, anchor_hash)
            return id
        }

        fn get(id: u64) -> EvolutionaryFeedbackOntologicalReconciliationState {
            return self.entries[id]
        }
    }
}
