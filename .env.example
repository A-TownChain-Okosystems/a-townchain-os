# A-TownChain OS — Environment Variables
# Kopiere nach .env und befülle deine Werte

# API-Schlüssel (komma-getrennt)
API_KEYS=atc-dev-key-2026,your-custom-key

# Datenbank
ATC_DB_URL=postgresql://atc:atc@localhost:5432/atcdb

# KI-APIs
GEMINI_API_KEY=your-gemini-key-here
OPENAI_API_KEY=your-openai-key-here

# P2P Netzwerk
ATC_BOOTSTRAP_HOST=localhost
ATC_BOOTSTRAP_PORT=4001
ATC_NODE_PORT=4002

# Security
JWT_SECRET=change-me-in-production
ATC_CHAIN_ID=atc-mainnet-1

# Monitoring
PROMETHEUS_PORT=9090
LOG_LEVEL=INFO
